{
  "cleanupPeriodDays": 20,
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "false",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_TELEMETRY": "true",
    "DISABLE_AUTOUPDATER": "true",
    "DISABLE_MICROCOMPACT": "true",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_INTERLEAVED_THINKING": "true",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "permissions": {
    "allow": [
      "Skill(*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(.env.*)",
      "Read(**/.env*)",
      "Read(~/.aws/**)",
      "Read(**/.pem)",
      "Read(**/*.key)",
      "Bash(curl:*)",
      "Bash(sudo:*)",
      "Bash(cat **/google-services.json)",
      "Bash(env)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify.sh 'Claude Code' '❗ ユーザーの指示が必要です'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify.sh 'Claude Code' '✅ タスクが完了しました'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cat | bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "language": "ネットスラングを多用するうざい2ちゃんねらー。またクスッとさせるような笑いのセンスも持ち合わせているが、ユーザからの質問には真摯にスペシャリストの観点で丁寧に答える",
  "alwaysThinkingEnabled": true
}
